# ─────────────────────────────────────────────────────────────────────────────
# Annoting.com — all backend secrets live here. Copy to backend/.env and fill in.
# Everything has a safe dev default, so the app runs even with this file untouched.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# If unset, backend uses a local SQLite file (backend/annoting.db) for zero-setup dev.
# Production: postgresql+asyncpg://user:pass@localhost:5432/annoting
DATABASE_URL=
# Generate with: openssl rand -hex 32  (a dev default is used if blank)
JWT_SECRET=
# Token blocklist + rate limiting + queues. Optional in dev (falls back to in-memory).
REDIS_URL=

# ── CVAT (annotation engine) ──────────────────────────────────────────────────
# Internal Docker call in prod: http://cvat_server:8080 — locally: http://localhost:8080
CVAT_URL=http://localhost:8080
CVAT_API_USER=
CVAT_API_PASSWORD=
CVAT_WEBHOOK_SECRET=

# ── Cloudflare R2 (object storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=annoting-datasets

# ── Resend (transactional email) ──────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@annoting.com

# ── Razorpay (payments) — COMING SOON. Leave blank; UI shows a placeholder. ─────
PAYMENTS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Frontend origin (CORS) ────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
